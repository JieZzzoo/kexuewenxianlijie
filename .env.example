# ============================================================
#  科学文献精读工作流 — 环境变量模板
#  用法：cp .env.example .env  然后填入你自己的 key
#  （.env 已在 .gitignore 中，不会被提交到 git）
# ============================================================

# --- MinerU 云端 PDF 解析 token ---
# 注册 https://mineru.net → 控制台 → API → 申请 API Token（Bearer JWT）
MINERU_TOKEN=

# --- DeepSeek API key（正文 + 表格 文本分析）---
# 注册 https://platform.deepseek.com → API keys → 创建（形如 sk-xxxx）
DEEPSEEK_API_KEY=

# --- 阿里云百炼 DashScope key（图片真·视觉分析，qwen3-vl-plus）---
# 申请 https://bailian.console.aliyun.com → API-KEY（形如 sk-xxxx）
DASHSCOPE_API_KEY=

# --- QQ 邮箱 SMTP（发件人）---
# 发件邮箱（你的 QQ 邮箱完整地址）
QQ_SMTP_USER=your_account@qq.com
# QQ 邮箱「授权码」(16 位字母，不是登录密码！)
#   获取：QQ邮箱网页版 → 设置 → 账号与安全 → 安全管理
#        → 开启 IMAP/SMTP 服务 → 生成授权码（按提示短信/扫码验证）
QQ_SMTP_AUTHCODE=
# 收件邮箱（报告发给谁；留空则默认发给上面的 QQ_SMTP_USER）
QQ_MAIL_TO=
